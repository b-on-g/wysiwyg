$mol_check_list $mol_view
	dictionary *
	Option* $mol_check
		checked? <=> option_checked*? false
		label <= option_label* /
			<= option_title* \
		enabled <= option_enabled* <= enabled true
		hint <= option_hint* \
		minimal_height 24
	options *
	keys /string
	sub <= items /$mol_check

$mol_switch $mol_check_list
	value? \

$bog_blitz $mol_page
	title @ \Blitz Quiz
	pages *
		lobby <= Lobby $bog_blitz_lobby
		admin <= Admin $bog_blitz_admin
		profile <= Profile $bog_blitz_profile_page
		feedback <= Feedback $bog_feedback2_form
			feedback_id \blitz
	nav_options *
		lobby \Лобби
		admin \Админ
		profile \Профиль
	Navbar $mol_switch
		value? <=> screen? \lobby
		options <= nav_options
	Mobile_nav $mol_switch
		value? <=> screen? \lobby
		options <= nav_options
	Mobile_menu $mol_pop
		showed? <=> mobile_menu_showed? false
		Anchor <= Mobile_menu_trigger $mol_check
			checked? <=> mobile_menu_showed? false
			sub /
				<= Mobile_menu_icon $mol_icon_menu
		bubble_content /
			<= Mobile_nav 
	tools /
		<= Feedback_link $mol_link
			arg *
				screen \feedback
			sub /
				<= Feedback_icon $mol_icon_message_draw
		<= Settings $mol_pick
			hint \Настройки
			trigger_content /
				<= Settings_icon $mol_icon_cog
			bubble_content /
				<= Settings_content $mol_row sub /
					<= Status $giper_baza_status
					<= Theme_toggle $bog_theme_toggle theme_auto <= Theme
					<= Sources $mol_link_source uri \https://github.com/b-on-g/blitz
				<= Powered $mol_text text \
					\Пишите нам в [Telegram](https://t.me/@Dev_Cmyser)
					\*Создано на [$mol](https://mol.hyoo.ru/#!section=docs/=4kd8nv_evh111) и [Giper Baza](https://t.me/mol_news/226)*
		<= Radio $bog_blitz_radio
	head /
		<= Title
		<= Navbar
		<= Tools
		<= Mobile_menu
	plugins /
		<= Theme $bog_theme_auto
			theme_light \$mol_theme_calm_light
			theme_dark \$mol_theme_calm_dark
			themes /
				\$mol_theme_calm_light
				\$mol_theme_calm_dark
	body <= screen_body /

$bog_blitz_profile_page $mol_page
	Head null
	body /
		<= Card $mol_view
			sub /
				<= Avatar_circle $mol_view
					sub /
						<= avatar_preview null
				<= Avatar $mol_button_open
					sub /
						<= Avatar_label $mol_paragraph
							title @ \Change photo
						<= Avatar_native $mol_button_open_native
							files? <=> avatar_files? /File
							accept \image/*
							multiple false
				<= Name_row $mol_view
					sub /
						<= Name_input $mol_string_button
							hint @ \Your name
							value? <=> profile_name? \
				<= Stats $mol_view
					sub <= stat_rows /
				<= Fun_card $mol_view
					sub /
						<= Fun_title $mol_paragraph
							title @ \Your Quiz Persona
						<= Fun_text $mol_paragraph
							title <= persona_text \
		<= Games_section $mol_view
			sub /
				<= Games_title $mol_paragraph
					title \История игр
				<= Games_search $mol_search
					query? <=> games_query? \
				<= Games_list $mol_list
					rows <= game_rows /
				<= Games_empty $mol_paragraph
					title <= games_empty_text \
	Avatar_image $mol_image
		uri <= avatar_uri \
	Avatar_icon $mol_avatar
		id <= player_id \
	Stat_row* $mol_view
		sub /
			<= Stat_label* $mol_paragraph
				title <= stat_label* \
			<= Stat_value* $mol_paragraph
				title <= stat_value* \
	Game_row* $mol_link
		arg <= game_arg* *
		sub /
			<= Game_info* $mol_view
				sub /
					<= Game_title* $mol_paragraph
						title <= game_title* \
					<= Game_details* $mol_paragraph
						title <= game_details* \
			<= Game_score* $mol_paragraph
				title <= game_score* \

