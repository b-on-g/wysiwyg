			<= Icon $mol_icon_music
	bubble_content /
		<= Menu $mol_view
			sub <= menu_content /
				<= Volume_row $mol_view
					sub /
						<= Volume_label $mol_string_button
							value? <=> volume_input? \
						<= Volume_up $mol_button_minor
							title \+
