$bog_wysiwyg_menu $mol_view
	showed? false
	picked?val \
	index? 0
	pos_y? 0
	pos_x? 0
	commands /
	Option* $mol_button_minor
		title <= option_title* \
		click?event <=> option_click*?event null
		attr *
			^
			bog_wysiwyg_menu_option_active <= option_active* false
	sub <= option_rows /
	attr *
		^
		bog_wysiwyg_menu_showed <= showed?
	style *
		^
		top <= pos_y_str \0px
		left <= pos_x_str \0px
