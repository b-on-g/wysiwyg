$bog_wysiwyg_comment_thread $mol_view
	comment_land_link \
	comment_count 0
	sub /
		<= Comments $mol_list
			rows <= comment_views /
		<= Input_row $mol_view
			sub /
				<= Input $mol_textarea
					hint @ \Write a comment...
					value? <=> draft? \
				<= Send $mol_button_minor
					title @ \Send
					click?event <=> send?event null
	Comment_row* $mol_view
		sub /
			<= Comment_head* $mol_view
				sub /
					<= Comment_avatar* $mol_avatar
						id <= comment_author_id* \
					<= Comment_author* $mol_paragraph
						title <= comment_author* \
			<= Comment_text* $mol_paragraph
				title <= comment_text* \
