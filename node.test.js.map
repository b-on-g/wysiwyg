$bog_feedback2_form $mol_page
	Head null
	feedback_id \
	registry_link \4o4ds4yH_SXDxOCPR
	title @ \Feedback ( one per user )
	tools /
		<= Close null
	body /
		<= Prompt $mol_text
			text <= prompt \
		<= Entry_my $mol_textarea
			hint @ \Your feedback
			value? <=> draft_text? \
		<= Contact_field $mol_string
			hint @ \Contact (optional)
			value? <=> draft_contact? \
		<= Submit $mol_button_major
			title <= submit_title \
			click? <=> submit? null
		<= Entries $mol_section
			title @ \All feedback
			content <= entry_rows /
				<= Entry_row*0 $mol_section
					title <= entry_row_contact* \
					content /
						<= Entry_row_text* $mol_text
							text <= entry_row_text* \
	Not_configured $mol_status
		message @ \Form not yet configured
	Waiting $mol_paragraph
		title <= waiting_title @ \Waiting…
